# .env.local — Split Deployment (Local Machine)
# Copy to .env.local and fill in your values

# ── LiveKit ───────────────────────────────────────────────────────────────────
LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── STT (Whisper على vast.ai عبر Tailscale) ───────────────────────────────────
STT_PROVIDER=whisper
STT_BASE_URL=http://<TAILSCALE_IP>:11435/v1
STT_MODEL=dev-ahmedhany/whisper-large-v3-arabic-ft-v3-ct2-int8
STT_API_KEY=no-key-needed

# ── LLM (Groq cloud) ─────────────────────────────────────────────────────────
# Available: llama-3.3-70b-versatile | llama-3.1-8b-instant | openai/gpt-oss-120b
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# ── TTS (Groq Orpheus cloud) ──────────────────────────────────────────────────
TTS_VOICE=fahad

# ── Groq API Key (shared: LLM + TTS) ─────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here

# ─────────────────────────────────────────────────────────────────────────────
# SIP Configuration (مطلوب فقط لتفعيل الاتصالات الهاتفية)
# ─────────────────────────────────────────────────────────────────────────────

# رقمك من Twilio — لو عندك أكتر من رقم افصل بينهم بفاصلة
# مثال: +966501234567,+966507654321
SIP_PROVIDER_NUMBERS=+966XXXXXXXXX

# Termination URI من Twilio (Elastic SIP Trunking → Trunks → Termination)
# مثال: my-trunk.pstn.twilio.com
SIP_OUTBOUND_HOST=your-trunk.pstn.twilio.com

# Credential List اللي أنشأتها في Twilio
SIP_USERNAME=your_sip_username
SIP_PASSWORD=your_sip_password

# Outbound Trunk ID — بيتعبى تلقائياً بعد تشغيل sip_setup.py
SIP_OUTBOUND_TRUNK_ID=

# ngrok URL (بدون https://) — بتحتاجه تضيفه في Twilio كـ Origination URI
# مثال: your-name.ngrok-free.app
# الـ Origination URI الكامل: sip:your-name.ngrok-free.app;transport=tcp
NGROK_DOMAIN=your-name.ngrok-free.app

# ngrok auth token — من https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken
