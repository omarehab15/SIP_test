# .env.remote.example — Copy to .env.remote (usually no changes needed)
# Used with: docker compose -f docker-compose.remote.yml -f docker-compose.remote-gpu.yml --env-file .env.remote up

# ── LLM (llama.cpp) ────────────────────────────────────────────────────────────
LLAMA_HF_REPO=unsloth/gemma-4-26B-A4B-it-GGUF
LLAMA_HF_FILE=gemma-4-26B-A4B-it-UD-Q3_K_M.gguf
LLAMA_MODEL_ALIAS=gemma4
LLAMA_HOST_PORT=11436
LLAMA_CTX_SIZE=49152   # = 4096 tokens × 12 parallel slots
LLAMA_PARALLEL=12

# ── STT (Whisper via VoxBox) ───────────────────────────────────────────────────
VOXBOX_HF_REPO_ID=dev-ahmedhany/whisper-large-v3-arabic-ft-v3-ct2-int8

# ── TTS ────────────────────────────────────────────────────────────────────────
# TTS is handled by Groq cloud (configured in .env.local on the local machine)
TTS_VOICE=fahad